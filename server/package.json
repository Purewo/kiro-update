{
  "name": "kiro-web-server",
  "version": "0.1.0",
  "description": "Kiro reverse proxy as a Linux web service (Manager backend, sans Electron)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.2.0",
    "fastify": "^5.6.0",
    "js-tiktoken": "^1.0.21",
    "node-forge": "^1.3.3",
    "pino-pretty": "^13.1.3",
    "socks": "^2.8.9",
    "undici": "^7.19.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.11",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22"
  }
